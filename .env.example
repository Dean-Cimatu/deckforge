# ── DeckForge environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.

# MongoDB connection string (docker-compose uses the mongo service; override for Atlas)
MONGODB_URI=mongodb://localhost:27017/deckforge

# JWT signing secret — generate a strong random value for production:
#   openssl rand -hex 64
JWT_SECRET=dev-secret-change-me

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# CORS allowed origin (the web frontend URL)
CORS_ORIGIN=http://localhost:5173

# Vite env vars (prefixed VITE_ are exposed to the browser bundle)
# Leave blank for local dev — the Vite dev proxy handles /api automatically.
# Set to https://deckforge-api.onrender.com for production builds.
VITE_API_BASE=
