{
  "name": "@deckforge/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs --external:*.node --external:jsdom --external:canvas",
    "start": "node dist/index.cjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@deckforge/shared": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "youtube-transcript": "^1.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.12",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.23.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "vitest": "^2.0.4"
  }
}
